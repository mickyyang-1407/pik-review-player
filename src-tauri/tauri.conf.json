{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pik Review",
  "version": "0.1.0",
  "identifier": "com.mickydigitalstudio.pikreview",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pik Review",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
